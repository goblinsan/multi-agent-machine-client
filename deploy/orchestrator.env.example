# Orchestrator node — coordinator + persona workers. CPU-only; no GPU required.

# --- Dashboard (the separate project-dashboard service that stores the plans) ---
# Set both to the deployed service's published URL.
DASHBOARD_BASE_URL=http://<dashboard-host>:<port>
DASHBOARD_API_URL=http://<dashboard-host>:<port>

# --- Transport ---
# local  = coordinator + workers in one process on this node (no Redis). Recommended
#          for the minimal offboard where the orchestrator lives on a single node.
# redis  = split workers across machines via a shared Redis (set REDIS_URL).
TRANSPORT_TYPE=local
# REDIS_URL=redis://<redis-node>:6379

# --- Where repos are cloned/worked on this node ---
PROJECT_BASE=/srv/machine-client/repos

# --- Model endpoints (per-persona routing) ---
# Default endpoint for personas without an explicit override:
LMS_BASE_URL=http://<small-model-node>:1234
# Heavy generative roles -> the 14B node:
PERSONA_ENDPOINTS_JSON={"lead-engineer":"http://<14b-node>:5314","implementation-planner":"http://<14b-node>:5314","analyst":"http://<14b-node>:5314"}
# Model id per persona (14B roles use the 14B model id; the rest the small model id):
PERSONA_MODELS_JSON={"lead-engineer":"<14b-model-id>","implementation-planner":"<14b-model-id>","analyst":"<14b-model-id>","context":"<small-model-id>","code-reviewer":"<small-model-id>","security-review":"<small-model-id>","tester-qa":"<small-model-id>","devops":"<small-model-id>","project-manager":"<small-model-id>","coordination":"<small-model-id>","researcher":"<small-model-id>"}

# Planning gate is deterministic; the LLM plan-evaluator stays retired.
PLANNING_EVALUATOR=off

# --- Git auth for pushing task branches to your forge (Forgejo/GitHub/...) ---
GIT_AUTH_USERNAME=<forge-user>
# GIT_AUTH_TOKEN=<token>

# --- Artifacts persisted to the dashboard API rather than committed to git ---
MA_ARTIFACTS_MODE=api
